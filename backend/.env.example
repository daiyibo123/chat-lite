# ===== 基础 =====
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

# ===== 数据库 =====
DATABASE_URL=sqlite:///./data/chat_lite.db

# ===== 安全 =====
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRE_MINUTES=10080
KEY_SECRET=change_this_to_another_long_random_secret

# ===== 管理员 =====
ADMIN_USERNAMES=admin
ADMIN_PASSWORD=change_this_admin_password

# ===== sub2api =====
SUB2API_BASE=https://www.dai1bo.tech

# ===== CORS =====
CORS_ORIGINS=https://chat.dai1bo.tech,http://localhost
